<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="600.0" prefWidth="450.0" style="-fx-background-color: #f5f5f5;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.chatappexam.ClientController">
    <top>
        <VBox spacing="5" style="-fx-background-color: #2c3e50; -fx-padding: 10 15;">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label fx:id="lblUsername" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px;" text="User" />
                <HBox HBox.hgrow="ALWAYS" />
                <Button fx:id="btnDisconnect" onAction="#disconnectOnAction" style="-fx-background-color: #ff4444; -fx-text-fill: white; -fx-font-weight: bold;         -fx-background-radius: 5; -fx-padding: 5 15; -fx-cursor: hand;" text="Disconnect" />
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: #2c3e50; -fx-background-radius: 8; -fx-padding: 8 12;">
                <VBox spacing="2">
                    <Label style="-fx-text-fill: #90EE90; -fx-font-size: 11px;" text="Item" />
                    <Label fx:id="lblItemName" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;" text="..." />
                </VBox>
                <HBox HBox.hgrow="ALWAYS" />
                <VBox alignment="CENTER_RIGHT" spacing="2">
                    <Label style="-fx-text-fill: #90EE90; -fx-font-size: 11px;" text="Current Highest Bid" />
                    <Label fx:id="lblHighestBid" style="-fx-text-fill: #FFD700; -fx-font-weight: bold;" text="Rs. 0.00">
                        <font><Font name="System Bold" size="18.0" /></font>
                    </Label>
                </VBox>
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background: #E5DDD5;" vbarPolicy="ALWAYS">
            <content>
                <TextArea fx:id="txtBidHistory" editable="false" prefHeight="264.0" prefWidth="435.0" style="-fx-background-color: #E5DDD5; -fx-font-size: 13px;         -fx-padding: 10; -fx-border-color: transparent;" wrapText="true" />
            </content>
        </ScrollPane>
    </center>

    <bottom>
        <VBox spacing="8" style="-fx-background-color: #F0F0F0; -fx-padding: 10 15 15 15;">
            <HBox alignment="CENTER" spacing="5">
                <Button onAction="#quickBid100" style="-fx-background-radius: 15; -fx-min-width: 55px;         -fx-background-color: #DCF8C6; -fx-font-weight: bold;" text="+100" />
                <Button onAction="#quickBid500" style="-fx-background-radius: 15; -fx-min-width: 55px;         -fx-background-color: #DCF8C6; -fx-font-weight: bold;" text="+500" />
                <Button onAction="#quickBid1000" style="-fx-background-radius: 15; -fx-min-width: 55px;         -fx-background-color: #DCF8C6; -fx-font-weight: bold;" text="+1000" />
                <Button onAction="#quickBid5000" style="-fx-background-radius: 15; -fx-min-width: 55px;         -fx-background-color: #DCF8C6; -fx-font-weight: bold;" text="+5000" />
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="8">
                <TextField fx:id="txtBidAmount" promptText="Enter bid amount (Rs.)" style="-fx-background-radius: 20; -fx-padding: 10 15; -fx-font-size: 14px;" HBox.hgrow="ALWAYS" />
                <Button fx:id="btnPlaceBid" onAction="#placeBidOnAction" style="-fx-background-radius: 20; -fx-min-width: 110px; -fx-min-height: 40px; -fx-background-color: #2c3e50; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-cursor: hand;" text="PLACE BID ➤" />
            </HBox>
        </VBox>
    </bottom>
</BorderPane>
